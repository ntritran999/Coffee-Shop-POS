<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#F9F3EB">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <Ellipse Width="100" Height="100" Fill="#D97724">
                    <Ellipse.ContextFlyout>
                        <Flyout />
                    </Ellipse.ContextFlyout>
                </Ellipse>

                <TextBlock Text="POS Cà Phê" FontSize="32" FontWeight="Bold" Foreground="#D97724" HorizontalAlignment="Center"/>
                <TextBlock Text="&quot;Giải pháp quản lý quán chuyên nghiệp cho mọi không gian cà phê Việt&quot;" 
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300" Foreground="#888"/>

                <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <Border Background="White" CornerRadius="8" Padding="20,10" >
                        <StackPanel>
                            <TextBlock Text="500+" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Đối tác tin dùng" FontSize="12" Foreground="Gray"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="20,10" >
                        <StackPanel>
                            <TextBlock Text="24/7" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hỗ trợ kỹ thuật" FontSize="12" Foreground="Gray"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="White">
            <FontIcon Glyph="&#xECAD;" FontSize="200" Foreground="#F5F5F5" 
                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,20,0"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Spacing="25">
                <StackPanel Spacing="5">
                    <TextBlock Text="Chào mừng trở lại" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="Vui lòng đăng nhập để bắt đầu phiên làm việc của bạn" Foreground="Gray"/>
                </StackPanel>

                <Border Background="White" BorderBrush="#EEE" BorderThickness="1" CornerRadius="12" Padding="30">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Tên đăng nhập" FontWeight="Medium"/>
                            <Grid>
                                <TextBox PlaceholderText="admin_pos" 
                                     Padding="35,7,10,7" 
                                     HorizontalAlignment="Stretch"
                                     CornerRadius="8"
                                     PlaceholderForeground="#D97724"/>
                                <FontIcon Glyph="&#xE77B;" 
                                      FontSize="16" 
                                      Foreground="Gray" 
                                      HorizontalAlignment="Left" 
                                      Margin="12,0,0,0" 
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <Grid>
                                <TextBlock Text="Mật khẩu" FontWeight="Medium"/>
                                <HyperlinkButton Content="Quên mật khẩu?" FontSize="12" Foreground="#D97724" 
                                                 HorizontalAlignment="Right" Padding="0"/>
                            </Grid>
                            <Grid>
                                <PasswordBox PlaceholderText="••••••••" 
                                     Padding="35,7,40,7" 
                                     HorizontalAlignment="Stretch"
                                     CornerRadius="8"
                                     PasswordRevealMode="Peek"/>
                                <FontIcon Glyph="&#xE72E;" 
                                      FontSize="16" 
                                      Foreground="Gray" 
                                      HorizontalAlignment="Left" 
                                      Margin="12,0,0,0" 
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <CheckBox Content="Nhớ đăng nhập" FontSize="14"/>

                        <Button Content="Đăng nhập" Background="#D97724" Foreground="White" 
                                HorizontalAlignment="Stretch" Padding="15" CornerRadius="8" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Grid>
                    <TextBlock Text="Phiên bản v1.0.4" Foreground="Gray" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <SymbolIcon Symbol="Setting" Margin="0,0,5,0"/>
                        <Button 
                            x:Name="ConfigServer"
                            Click="ConfigServer_Click"
                            Content="Cấu hình server"
                            Foreground="#D97724"
                            Style="{StaticResource SubtleButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <TextBlock Text="© 2024 POS Cà Phê • Hệ thống quản lý vận hành thông minh tối ưu cho người Việt" 
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20" FontSize="11" Foreground="Gray"/>
        </Grid>


    </Grid>
</Page>
