<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.ViewProduct"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:model="using:Client.Models"
    xmlns:converter="using:Client.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converter:FormatPrice x:Key="Price" />
        <converter:FirstImageLinkConverter x:Key="FirstImageLinkConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"
                                              TrueValue="Visible"
                                              FalseValue="Collapsed" />

        <DataTemplate x:Key="ThumbnailTemplate" x:DataType="model:Product">
            <Border Width="250" Margin="10" CornerRadius="10" Background="White">
                <StackPanel>
                    <Image Source="{Binding Image, Converter={StaticResource FirstImageLinkConverter}}" Width="120" Height="120" Stretch="UniformToFill" />
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="5,5,5,0" Foreground="Black" />
                    <TextBlock Text="{Binding Price, Converter={StaticResource Price}}" Foreground="Orange" Margin="5,0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CategoryTemplate" x:DataType="model:Category">
            <Grid Margin="10, 16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1"
                           Text="{x:Bind CategoryName}"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           Foreground="Black" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#F5F5F5"
              RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Danh mục" FontSize="30" Foreground="Black" Margin="10, 0" />
            <TextBlock Grid.Row="1" Text="Phân loại thực đơn" FontSize="20" Foreground="Black" Margin="10,0" />

            <ListView Grid.Row="2"
                      x:Name="CategoryList"
                      ItemsSource="{x:Bind CategoryView.Categories}"
                      SelectedItem="{x:Bind CategoryView.SelectedCategory, Mode=OneWay}"
                      ItemTemplate="{StaticResource CategoryTemplate}"
                      SelectionChanged="CategoryList_SelectionChanged"
                      Margin="32, 0, 32, 0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0, 0, 8, 0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="CornerRadius" Value="28"/>
                        <Setter Property="Background" Value="#EAEAEA"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ListViewItemPresenter
                        ContentTransitions="{TemplateBinding ContentTransitions}"
                        ContentMargin="{TemplateBinding Padding}"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        SelectionCheckMarkVisualEnabled="False"
                        PointerOverBackground="#D5D5D5"
                        SelectedBackground="#D97724"
                        SelectedPointerOverBackground="#C76B1F"
                        SelectedPressedBackground="#AB5D1A"
                        SelectedForeground="White" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <Button Grid.Row="3" Content="Thêm loại sản phẩm" Margin="10" Click="AddCategory_Click" />
        </Grid>

        <Grid Grid.Column="1" Background="#fbfaf8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="10" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="SearchBox"
                             PlaceholderText="Tìm kiếm theo tên sản phẩm..."
                             Width="260"
                             TextChanged="SearchBox_TextChanged" />

                    <ComboBox x:Name="SortComboBox" Width="180" SelectionChanged="SortComboBox_SelectionChanged">
                        <ComboBoxItem Content="Mặc định" />
                        <ComboBoxItem Content="Tên (A-Z)" />
                        <ComboBoxItem Content="Tên (Z-A)" />
                        <ComboBoxItem Content="Giá (thấp đến cao)" />
                        <ComboBoxItem Content="Giá (cao đến thấp)" />
                    </ComboBox>

                    <Button Content="Thêm sản phẩm" Click="AddProduct_Click" />
                    <Button Content="Import Excel/Access" Click="ImportProducts_Click" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="MinPriceBox" Width="140" PlaceholderText="Giá từ" InputScope="Number" />
                    <TextBox x:Name="MaxPriceBox" Width="140" PlaceholderText="Giá đến" InputScope="Number" />
                    <Button Content="Lọc giá" Click="ApplyPriceFilter_Click" />
                    <Button Content="Xóa lọc giá" Click="ClearPriceFilter_Click" />
                </StackPanel>
            </StackPanel>

            <ListView Grid.Row="1"
                      Name="ProductList"
                      ItemsSource="{x:Bind ProductView.PagedProducts, Mode=OneWay}"
                      ItemTemplate="{StaticResource ThumbnailTemplate}"
                      SelectedItem="{x:Bind ProductView.SelectedProduct, Mode=TwoWay}">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <toolkit:WrapPanel />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
            </ListView>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,12" Spacing="12">
                <Button Click="PrevPage_Click" IsEnabled="{x:Bind ProductView.CanGoPreviousPage, Mode=OneWay}"
                        CornerRadius="20" Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="1">
                    <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                </Button>
                <TextBlock Text="{x:Bind ProductView.PageInfo, Mode=OneWay}" VerticalAlignment="Center" />
                <Button Click="NextPage_Click" IsEnabled="{x:Bind ProductView.CanGoNextPage, Mode=OneWay}"
                        CornerRadius="20" Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="1">
                    <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Column="2" Background="#F5F5F5">
            <StackPanel Name="HasSelectionTemplete"
                        Background="#F5F5F5"
                        Visibility="{x:Bind ProductView.HasSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Padding="16">
                <Button Background="Transparent" HorizontalAlignment="Right"
                        Command="{x:Bind ProductView.HideSelectedProductCommand}">
                    <FontIcon Glyph="&#xE711;" FontSize="12"/>
                </Button>
                <TextBlock Text="Chi tiết sản phẩm" FontSize="30" Foreground="Black" Margin="10" />
                <TextBlock Text="Thông tin chi tiết về sản phẩm đã chọn" FontSize="20" Foreground="Black" Margin="10,0" />

                <StackPanel Margin="10">
                    <ItemsControl ItemsSource="{x:Bind ProductView.SelectedProductImages, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Margin="0,0,8,8" CornerRadius="8" Background="White" Padding="4">
                                    <Image Source="{x:Bind}" Width="90" Height="90" Stretch="UniformToFill" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{x:Bind ProductView.SelectedProduct.Name, Mode=OneWay}" FontSize="24" FontWeight="Bold" Margin="0,10" Foreground="Black" />
                    <TextBlock Text="{x:Bind ProductView.SelectedProduct.Price, Mode=OneWay, Converter={StaticResource Price}}" FontSize="20" Foreground="Orange" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Xóa" Click="DeleteProduct_Click" Background="White" Foreground="Black" />
                        <Button Content="Sửa" Click="EditProduct_Click" Background="Orange" Foreground="White" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
