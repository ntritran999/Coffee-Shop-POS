<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.OrderListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <SplitView Name="orderSplitView"
               PanePlacement="Right"
           IsPaneOpen="False" OpenPaneLength="512" CompactPaneLength="48" DisplayMode="Overlay"
               Margin="36">
        <SplitView.Pane>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="10" Padding="16">
                    <TextBlock Text="MaDH" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE823;" FontSize="12"/>
                        <TextBlock Text="12:00 01/01/2026" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Row="1" BorderBrush="Black" BorderThickness="0,1,0,1" Background="White" Padding="16">
                    <Grid RowSpacing="16" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" CornerRadius="8" BorderBrush="Black" BorderThickness="1" Padding="8">
                            <StackPanel Orientation="Vertical" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE81D;" />
                                    <TextBlock Text="Vi tri"/>
                                </StackPanel>
                                <TextBlock Text="Ban 01" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" CornerRadius="8" BorderBrush="Black" BorderThickness="1" Padding="8">
                            <StackPanel Orientation="Vertical" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE77B;" />
                                    <TextBlock Text="Nhan vien"/>
                                </StackPanel>
                                <TextBlock Text="NV 01" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1" Grid.ColumnSpan="2" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEC32;" />
                                <TextBlock Text="Danh sach mon an" FontWeight="Bold"/>
                            </StackPanel>
                            <Border Grid.Row="1" CornerRadius="8" Padding="16" BorderBrush="Black" BorderThickness="1">
                                <ListView SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="Black" BorderThickness="0, 0, 0, 1" Padding="0, 0, 0, 16" Margin="0, 0, 0, 16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                                                        <Border BorderBrush="Black" BorderThickness="1" CornerRadius="4" Padding="4"
                                                                VerticalAlignment="Top">
                                                            <TextBlock Text="2x" FontWeight="Bold"/>
                                                        </Border>
                                                        <StackPanel Orientation="Vertical" Spacing="8">
                                                            <TextBlock Text="Ca phe" FontWeight="Bold"/>
                                                            <TextBlock Text="35.000d/mon"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="70.000d" FontWeight="Bold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>

                                    <x:String>Test</x:String>
                                    <x:String>Test</x:String>
                                    <x:String>Test</x:String>
                                    <x:String>Test</x:String>
                                    <x:String>Test</x:String>
                                    <x:String>Test</x:String>
                                    <x:String>Test</x:String>
                                    <x:String>Test</x:String>
                                    <x:String>Test</x:String>
                                </ListView>
                            </Border>
                        </Grid>
                                    
                        <StackPanel Grid.ColumnSpan="2" Grid.Row="2" Orientation="Vertical" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xF0E3;" />
                                <TextBlock Text="GHI CHU TU KHACH" FontWeight="Bold"/>
                            </StackPanel>
                            <Border Padding="16" CornerRadius="8" BorderBrush="Black" BorderThickness="1">
                                <TextBlock Text="Ghi chu" FontStyle="Italic"/>
                            </Border>
                        </StackPanel>
                        <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="Black" BorderThickness="0, 1, 0, 0" Padding="0, 8, 0, 0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Tam tinh"/>
                                <TextBlock Grid.Column="1" Text="100.000d"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="#f6f5f3" Padding="16">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" />
                                <TextBlock Text="Huy don"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8C7;" />
                                <TextBlock Text="Thanh toan"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </SplitView.Pane>
        <Grid RowSpacing="20" Background="#fbfaf8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Padding="20" Grid.Row="0" CornerRadius="8" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0, 0, 0, 20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical" Spacing="20" Grid.Column="0">
                            <AutoSuggestBox PlaceholderText="Tim ma don, ten ban, ..."
                                    QueryIcon="Find"
                                    HorizontalAlignment="Left"/>
                            <StackPanel Spacing="10" Orientation="Horizontal">
                                <CalendarDatePicker
                                VerticalAlignment="Center"
                                MinWidth="130"/>
                                <TextBlock Text="—" VerticalAlignment="Center"/>
                                <CalendarDatePicker
                                VerticalAlignment="Center"
                                MinWidth="130"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="10">
                            <Button>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE74E;"/>
                                    <TextBlock Text="Xuat Excel"/>
                                </StackPanel>
                            </Button>

                            <Button>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE710;"/>
                                    <TextBlock Text="Tao don moi"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <Button Content="Tất cả"/>
                            <Button Content="Mới tạo"/>
                            <Button Content="Đã thanh toán"/>
                            <Button Content="Đã hủy"/>
                        </StackPanel>
                        <Button Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE71C;"/>
                                <TextBlock Text="Bộ lọc nâng cao"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Row="1"
        Background="White"
        CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView Grid.Row="0" SelectionMode="None"
      ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <ListView.Header>
                            <Border BorderThickness="0,0,0,1" Padding="20,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Mã đơn"
                       FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="Thời gian"
                       FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="Bàn / Vị trí"
                       FontWeight="SemiBold" FontSize="13"
                       HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="Tổng tiền (đ)"
                       FontWeight="SemiBold" FontSize="13"
                       HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Trạng thái"
                       FontWeight="SemiBold" FontSize="13"
                       HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="Thao tác"
                       FontWeight="SemiBold" FontSize="13"
                       HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ListView.Header>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter HorizontalAlignment="Stretch"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border
                            BorderThickness="0,0,0,1"
                            Padding="20,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="DH00124"
                                   FontWeight="SemiBold"
                                   FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="10:45  22/05/2024"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Bàn 04"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="145,000"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4" Text="Đã thanh toán"
                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="5" Orientation="Horizontal"
                                            HorizontalAlignment="Center" Spacing="2" VerticalAlignment="Center">
                                            <Button Background="Transparent" BorderThickness="0"
                                            Padding="6" CornerRadius="4" Click="Detail_Click">
                                                <FontIcon Glyph="&#xE7B3;" FontSize="14" Foreground="#666"/>
                                            </Button>
                                            <Button Background="Transparent" BorderThickness="0"
                                            Padding="6" CornerRadius="4">
                                                <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="#666"/>
                                            </Button>
                                            <Button Background="Transparent" BorderThickness="0"
                                            Padding="6" CornerRadius="4">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#666"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <x:String>Apricot</x:String>
                        <x:String>Banana</x:String>
                        <x:String>Cherry</x:String>
                    </ListView>


                    <Border Grid.Row="1"
                Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                           Text="Hiển thị 1-8 trong tổng số 42 đơn hàng"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button CornerRadius="20" Width="32" Height="32" Padding="0"
                            Background="Transparent" BorderThickness="1">
                                    <FontIcon Glyph="&#xE76B;" FontSize="11"/>
                                </Button>
                                <Button CornerRadius="20" Width="32" Height="32" Padding="0" BorderThickness="0">
                                    <TextBlock Text="1"
                                   FontWeight="SemiBold" FontSize="13"/>
                                </Button>
                                <Button CornerRadius="20" Width="32" Height="32" Padding="0"
                            BorderThickness="0">
                                    <TextBlock Text="2" FontSize="13"/>
                                </Button>
                                <Button CornerRadius="20" Width="32" Height="32" Padding="0"
                            BorderThickness="0">
                                    <TextBlock Text="3" FontSize="13"/>
                                </Button>
                                <TextBlock Text="..." VerticalAlignment="Center"
                               Margin="4,0"/>
                                <Button CornerRadius="20" Width="32" Height="32" Padding="0"
                            BorderThickness="0">
                                    <TextBlock Text="6" FontSize="13"/>
                                </Button>
                                <Button CornerRadius="20" Width="32" Height="32" Padding="0"
                            Background="Transparent" BorderThickness="1">
                                    <FontIcon Glyph="&#xE76C;" FontSize="11"/>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="8" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Số dòng mỗi trang:"
                               VerticalAlignment="Center"/>
                                <ComboBox Width="64" Height="32" FontSize="12" SelectedIndex="0">
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="32"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
            Background="#FFF3E8"
            CornerRadius="12"
            Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                    Width="36" Height="36" CornerRadius="18"
                    Background="#C8651B" VerticalAlignment="Center"
                    Margin="0,0,12,0">
                            <FontIcon Glyph="&#xE710;" FontSize="16" Foreground="White"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Đơn mới hôm nay"
                           FontSize="12"/>
                            <TextBlock Text="24 Đơn"
                           FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
            Background="#F5F5F5"
            CornerRadius="12"
            Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                    Width="36" Height="36" CornerRadius="18"
                    Background="#888" VerticalAlignment="Center"
                    Margin="0,0,12,0">
                            <FontIcon Glyph="&#xE71C;" FontSize="16" Foreground="White"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Đang xử lý"
                           FontSize="12"/>
                            <TextBlock Text="05 Đơn"
                           FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
            Background="#F1FBF4"
            CornerRadius="12"
            Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                    Width="36" Height="36" CornerRadius="18"
                    Background="#2E7D32" VerticalAlignment="Center"
                    Margin="0,0,12,0">
                            <FontIcon Glyph="&#xE712;" FontSize="16" Foreground="White"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Tổng doanh thu tạm tính"
                           FontSize="12"/>
                            <TextBlock Text="1,450,000 đ"
                           FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </SplitView>
    
</Page>
