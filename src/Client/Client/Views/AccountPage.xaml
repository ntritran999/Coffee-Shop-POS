<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:vm="using:Client.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <ScrollViewer Padding="30">
        <StackPanel Spacing="24">

            <!-- Page Header -->
            <Grid>
                <StackPanel>
                    <TextBlock Text="Danh sách nhân sự" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Foreground="Gray" FontSize="14" Margin="0,4,0,0">
                        <Run Text="Bạn đang có"/>
                        <Run Text="{x:Bind ViewModel.TotalAccounts, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="tài khoản hoạt động trong hệ thống."/>
                    </TextBlock>
                </StackPanel>

                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="#D97724" Foreground="White" CornerRadius="12" Padding="20,12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="Thêm tài khoản mới"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Account List -->
            <Border Background="White" CornerRadius="12" Padding="0">
                <StackPanel>
                    <!-- Table Header -->
                    <Grid Padding="24,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TÊN HIỂN THỊ &amp; TRẠNG THÁI" Foreground="#D97724" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                        <TextBlock Grid.Column="1" Text="TÊN ĐĂNG NHẬP" Foreground="#D97724" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                        <TextBlock Grid.Column="2" Text="PHÂN QUYỀN" Foreground="#D97724" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                        <TextBlock Grid.Column="3" Text="THAO TÁC" Foreground="#D97724" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50" Margin="0,0,12,0"/>
                    </Grid>

                    <!-- Account Items -->
                    <ListView ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:AccountListItem">
                                <Grid Padding="24,14" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name + Status -->
                                    <StackPanel Orientation="Horizontal" Spacing="12" Grid.Column="0">
                                        <PersonPicture Width="40" Height="40" DisplayName="{x:Bind DisplayName, Mode=OneWay}"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind LastActive, Mode=OneWay}" Foreground="Gray" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Username -->
                                    <TextBlock Grid.Column="1" Text="{x:Bind Username, Mode=OneWay}" VerticalAlignment="Center" Foreground="Gray"/>

                                    <!-- Role Badge -->
                                    <Border Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left"
                                            CornerRadius="12" Padding="12,6"
                                            Background="{x:Bind local:AccountPage.GetRoleBadgeBackground(IsAdmin), Mode=OneWay}"
                                            BorderBrush="{x:Bind local:AccountPage.GetRoleBadgeBorder(IsAdmin), Mode=OneWay}"
                                            BorderThickness="1">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="{x:Bind local:AccountPage.GetRoleIcon(IsAdmin), Mode=OneWay}"
                                                      FontSize="12"
                                                      Foreground="{x:Bind local:AccountPage.GetRoleForeground(IsAdmin), Mode=OneWay}"/>
                                            <TextBlock Text="{x:Bind Role, Mode=OneWay}" FontSize="12"
                                                       Foreground="{x:Bind local:AccountPage.GetRoleForeground(IsAdmin), Mode=OneWay}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Actions -->
                                    <Button Grid.Column="3" Background="Transparent" Padding="8" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE712;" FontSize="16" Foreground="Gray"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Summary -->
                    <Grid Padding="24,12">
                        <TextBlock Foreground="Gray" FontSize="12" VerticalAlignment="Center">
                            <Run Text="Hiển thị"/>
                            <Run Text="{x:Bind ViewModel.TotalAccounts, Mode=OneWay}"/>
                            <Run Text="trên tổng số"/>
                            <Run Text="{x:Bind ViewModel.TotalAccounts, Mode=OneWay}"/>
                            <Run Text="người dùng"/>
                        </TextBlock>
                        <Button HorizontalAlignment="Right" Background="Transparent" Padding="8">
                            <FontIcon Glyph="&#xE712;" FontSize="14" Foreground="Gray"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Divider -->
            <Grid Margin="0,8">
                <Border Height="1" Background="#E5E7EB" VerticalAlignment="Center"/>
                <Border Background="#F5F5F5" Padding="16,0" HorizontalAlignment="Center">
                    <TextBlock Text="THÔNG TIN CHI TIẾT" FontSize="11" FontWeight="SemiBold" Foreground="Gray" CharacterSpacing="100"/>
                </Border>
            </Grid>

            <!-- Add Account Form -->
            <Border Background="White" CornerRadius="12" Padding="30">
                <StackPanel Spacing="24">
                    <!-- Form Header -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Background="#FFF3E0" CornerRadius="20" Width="40" Height="40">
                            <FontIcon Glyph="&#xE77B;" Foreground="#D97724" FontSize="18"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Thêm tài khoản mới" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="Điền đầy đủ thông tin để tạo tài khoản truy cập hệ thống." Foreground="Gray" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Form Row 1: DisplayName + Role -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tên hiển thị" FontWeight="SemiBold"/>
                                <TextBlock Text=" *" Foreground="#E8533F"/>
                            </StackPanel>
                            <TextBox PlaceholderText="Ví dụ: Nguyễn Văn A"
                                     Text="{x:Bind ViewModel.NewDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Phân quyền truy cập" FontWeight="SemiBold"/>
                                <TextBlock Text=" *" Foreground="#E8533F"/>
                            </StackPanel>
                            <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{x:Bind ViewModel.SelectedRoleIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Nhân viên (Giới hạn quyền)"/>
                                <ComboBoxItem Content="Quản trị viên (Toàn quyền)"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Form Row 2: Username + Password -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tên đăng nhập" FontWeight="SemiBold"/>
                                <TextBlock Text=" *" Foreground="#E8533F"/>
                            </StackPanel>
                            <TextBox PlaceholderText="username"
                                     Text="{x:Bind ViewModel.NewUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Mật khẩu" FontWeight="SemiBold"/>
                                <TextBlock Text=" *" Foreground="#E8533F"/>
                            </StackPanel>
                            <PasswordBox PlaceholderText="••••••••"
                                         Password="{x:Bind ViewModel.NewPassword, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Note + Buttons -->
                    <Grid>
                        <TextBlock Text="* Các trường có dấu sao đỏ là thông tin bắt buộc phải điền."
                                   Foreground="Gray" FontSize="12" FontStyle="Italic" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                            <Button Content="Hủy bỏ" Padding="24,10" CornerRadius="8"
                                    Command="{x:Bind ViewModel.ClearFormCommand}"
                                    BorderBrush="#D97724" Foreground="#D97724"/>
                            <Button Padding="24,10" CornerRadius="8"
                                    Background="#D97724" Foreground="White"
                                    Command="{x:Bind ViewModel.SaveAccountCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                    <TextBlock Text="Lưu thay đổi"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <TextBlock Text="© 2024 POS Cà Phê • v1.0.4 • Hệ thống quản lý vận hành thông minh"
                       HorizontalAlignment="Center" Margin="0,0,0,20" FontSize="11" Foreground="Gray"/>

        </StackPanel>
    </ScrollViewer>
</Page>
