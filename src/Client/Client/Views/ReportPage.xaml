<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.ReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:vm="using:Client.ViewModels"
    xmlns:converters="using:Client.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Page.Resources>
        <converters:FilterStateConverter x:Key="BorderActiveConverter" ActiveColorHex="#D97724" InactiveColorHex="#00000000" />
        <converters:FilterStateConverter x:Key="TextActiveConverter" ActiveColorHex="#D97724" InactiveColorHex="#444444" />
    </Page.Resources>

    <ScrollViewer Padding="30">
        <StackPanel Spacing="25">
            <StackPanel Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Doanh thu &amp; Tài chính"
                            Foreground="{x:Bind ViewModel.Tab1Foreground, Mode=OneWay}"
                            Background="{x:Bind ViewModel.Tab1Background, Mode=OneWay}"
                            Command="{x:Bind ViewModel.SwitchTabCommand}" CommandParameter="Revenue"
                            CornerRadius="16" Padding="20,12"/>

                    <Button Content="Hiệu suất Sản phẩm" 
                            Foreground="{x:Bind ViewModel.Tab2Foreground, Mode=OneWay}"
                            Background="{x:Bind ViewModel.Tab2Background, Mode=OneWay}"
                            Command="{x:Bind ViewModel.SwitchTabCommand}" CommandParameter="Product"
                            CornerRadius="16" Padding="20,12"/>
                </StackPanel>

                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Ngày" Padding="20,8" CornerRadius="12" BorderThickness="1"
                            Foreground="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource TextActiveConverter}, ConverterParameter='0'}"
                            BorderBrush="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource BorderActiveConverter}, ConverterParameter='0'}"
                            Command="{x:Bind ViewModel.SelectTimeFilterCommand}" CommandParameter="Ngày"/>

                        <Button Content="Tuần" Padding="20,8" CornerRadius="12" BorderThickness="1"
                            Foreground="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource TextActiveConverter}, ConverterParameter='1'}"
                            BorderBrush="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource BorderActiveConverter}, ConverterParameter='1'}"
                            Command="{x:Bind ViewModel.SelectTimeFilterCommand}" CommandParameter="Tuần"/>

                        <Button Content="Tháng" Padding="20,8" CornerRadius="12" BorderThickness="1"
                            Foreground="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource TextActiveConverter}, ConverterParameter='2'}"
                            BorderBrush="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource BorderActiveConverter}, ConverterParameter='2'}"
                            Command="{x:Bind ViewModel.SelectTimeFilterCommand}" CommandParameter="Tháng"/>

                        <Button Content="Năm" Padding="20,8" CornerRadius="12" BorderThickness="1"
                            Foreground="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource TextActiveConverter}, ConverterParameter='3'}"
                            BorderBrush="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource BorderActiveConverter}, ConverterParameter='3'}"
                            Command="{x:Bind ViewModel.SelectTimeFilterCommand}" CommandParameter="Năm"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.SelectedDateRangeText, Mode=OneWay}" 
                                   VerticalAlignment="Center" Foreground="DimGray" FontStyle="Italic" Margin="0,0,10,0"/>

                        <Button ToolTipService.ToolTip="Chọn khoảng thời gian tùy chỉnh" Background="Transparent" BorderThickness="0">
                            <FontIcon Glyph="&#xE71C;" />
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="16" Width="240" Padding="4">
                                        <TextBlock Text="Tùy chỉnh thời gian" FontWeight="Bold" FontSize="15"/>
                                        <CalendarDatePicker Header="Từ ngày" Date="{x:Bind ViewModel.FromDate, Mode=TwoWay}"
                                                            DateFormat="{}{day.integer(2)}/{month.integer(2)}/{year.full}" HorizontalAlignment="Stretch"/>
                                        <CalendarDatePicker Header="Đến ngày" Date="{x:Bind ViewModel.ToDate, Mode=TwoWay}"
                                                            DateFormat="{}{day.integer(2)}/{month.integer(2)}/{year.full}" HorizontalAlignment="Stretch"/>
                                        <Button Content="Áp dụng" Command="{x:Bind ViewModel.ApplyDateFilterCommand}" 
                                                Background="#D97724" Foreground="White" CornerRadius="8" HorizontalAlignment="Right" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Grid ColumnSpacing="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="TỔNG DOANH THU" Foreground="Gray" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalRevenue, Mode=OneWay}" FontSize="22" FontWeight="Bold" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Bind ViewModel.RevenueChange, Mode=OneWay}" Foreground="#28A745" FontSize="11"/>
                                <TextBlock Text=" so với kỳ trước" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="LỢI NHUẬN ƯỚC TÍNH" Foreground="Gray" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                            <TextBlock Text="{x:Bind ViewModel.EstimatedProfit, Mode=OneWay}" FontSize="22" FontWeight="Bold" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Bind ViewModel.ProfitChange, Mode=OneWay}" Foreground="#28A745" FontSize="11"/>
                                <TextBlock Text=" so với kỳ trước" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="TRUNG BÌNH ĐƠN" Foreground="Gray" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                            <TextBlock Text="{x:Bind ViewModel.AverageOrder, Mode=OneWay}" FontSize="22" FontWeight="Bold" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Bind ViewModel.AverageOrderChange, Mode=OneWay}" Foreground="#E8533F" FontSize="11"/>
                                <TextBlock Text=" mỗi lượt khách" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="#FFF3E0" CornerRadius="12" Padding="10" HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40">
                            <FontIcon Glyph="&#xE7BF;" Foreground="#D97724" FontSize="16"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="TỔNG ĐƠN HÀNG" Foreground="Gray" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalOrders, Mode=OneWay}" FontSize="22" FontWeight="Bold" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Bind ViewModel.OrdersChange, Mode=OneWay}" Foreground="#28A745" FontSize="11"/>
                                <TextBlock Text=" đơn hoàn thành" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="#E8F5E9" CornerRadius="12" Padding="10" HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40">
                            <FontIcon Glyph="&#xE9D2;" Foreground="#28A745" FontSize="16"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid ColumnSpacing="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <Grid Visibility="{x:Bind ViewModel.RevenueChartVisibility, Mode=OneWay}">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Biểu đồ Doanh thu" FontWeight="Bold" FontSize="18"/>
                                        <TextBlock Text="Thống kê chi tiết doanh thu và lợi nhuận" Foreground="Gray" FontSize="13"/>
                                    </StackPanel>
                                    <HyperlinkButton Content="Tải báo cáo ↗" HorizontalAlignment="Right" Foreground="#D97724"/>
                                </Grid>
                                <Grid Margin="0,20,0,0" Height="280">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                        <TextBlock Text="Cao nhất" Foreground="Gray" FontSize="10" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                        <TextBlock Text="..." Foreground="Gray" FontSize="10" HorizontalAlignment="Right" Margin="0,100,8,0"/>
                                        <TextBlock Text="0" Foreground="Gray" FontSize="10" HorizontalAlignment="Right" Margin="0,100,8,0"/>
                                    </StackPanel>
                                    <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.WeeklyChartData, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:RevenueChartItem">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="50">
                                                    <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                                        <Border Background="#D97724" CornerRadius="4,4,0,0" Width="18" Height="{x:Bind RevenueBarHeight, Mode=OneWay}"/>
                                                        <Border Background="#F0A04B" CornerRadius="4,4,0,0" Width="18" Height="{x:Bind ProfitBarHeight, Mode=OneWay}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{x:Bind DayLabel, Mode=OneWay}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center" Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="10" Height="10" Fill="#D97724"/>
                                        <TextBlock Text="Doanh thu" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="10" Height="10" Fill="#F0A04B"/>
                                        <TextBlock Text="Lợi nhuận" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{x:Bind ViewModel.ProductChartVisibility, Mode=OneWay}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <StackPanel HorizontalAlignment="Left">
                                        <TextBlock Text="Biểu đồ Hiệu suất Sản phẩm" FontWeight="Bold" FontSize="18"/>
                                        <TextBlock Text="Xu hướng bán hàng theo từng danh mục" Foreground="Gray" FontSize="13"/>
                                    </StackPanel>
                                    <ComboBox ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                                              SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center" Width="200"
                                              Background="#F5F5F5" BorderThickness="0" CornerRadius="8">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding CategoryName}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,20,0,0" Height="280">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="1" HorizontalAlignment="Left" Width="500">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.ProductLines, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Grid/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ProductLineUI">
                                                    <Polyline Points="{x:Bind PointsString, Mode=OneWay}" 
                                                              Stroke="{x:Bind ColorHex}" StrokeThickness="3" StrokeLineJoin="Round"
                                                              VerticalAlignment="Top" HorizontalAlignment="Left"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.ProductLines, Mode=OneWay}" HorizontalAlignment="Center" Margin="0,16,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="5" HorizontalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ProductLineUI">
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,5">
                                                <Ellipse Width="10" Height="10" Fill="{x:Bind ColorHex}"/>
                                                <TextBlock Text="{x:Bind ProductName}" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Cơ cấu Danh mục" FontWeight="Bold" FontSize="18"/>
                        <TextBlock Text="Tỷ trọng doanh thu theo nhóm" Foreground="Gray" FontSize="13"/>
                        <Grid Height="150" Width="150" Margin="0,20,0,10">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryBreakdown, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CategoryItem">
                                        <Ellipse Width="150" Height="150" 
                         StrokeThickness="30" 
                         Stroke="{x:Bind ColorHex}" 
                         StrokeDashArray="{x:Bind DashArray}" 
                         StrokeDashOffset="{x:Bind DashOffset}"
                         HorizontalAlignment="Center" 
                         VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryBreakdown, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryItem">
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding ColorHex}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name, Mode=OneWay}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center">
                                            <Run Text="{x:Bind Percentage.ToString(), Mode=OneWay}"/><Run Text="%"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="© 2026 POS Cà Phê • v1.0.4 • Hệ thống quản lý vận hành thông minh" HorizontalAlignment="Center" Margin="0,0,0,20" FontSize="11" Foreground="Gray"/>
        </StackPanel>
    </ScrollViewer>
</Page>