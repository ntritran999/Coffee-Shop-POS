<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.ReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:vm="using:Client.ViewModels"
    xmlns:converters="using:Client.Converters"
    
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Page.Resources>
        <converters:FilterStateConverter x:Key="BorderActiveConverter" ActiveColorHex="#D97724" InactiveColorHex="#00000000" />
        <converters:FilterStateConverter x:Key="TextActiveConverter" ActiveColorHex="#D97724" InactiveColorHex="#444444" />
    </Page.Resources>



    <ScrollViewer Padding="30">
        <StackPanel Spacing="25">

            <!-- Tab Buttons: Doanh thu & Tài chính / Hiệu suất Sản phẩm -->
            <StackPanel Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Doanh thu &amp; Tài chính"
                            Foreground="White"
                            Background="#D97724"
                            CornerRadius="16" Padding="20,12"/>
                    <Button Content="Hiệu suất Sản phẩm" 
                            Style="{StaticResource SubtleButtonStyle}" 
                            CornerRadius="16" Padding="20,12"/>
                </StackPanel>

                <!-- Time filter + Date range -->
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Ngày" Padding="20,8" CornerRadius="12" BorderThickness="1"
                            Foreground="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource TextActiveConverter}, ConverterParameter='0'}"
                            BorderBrush="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource BorderActiveConverter}, ConverterParameter='0'}"
                            Command="{x:Bind ViewModel.SelectTimeFilterCommand}" CommandParameter="Ngày"/>  

                        <Button Content="Tuần" Padding="20,8" CornerRadius="12" BorderThickness="1"
                            Foreground="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource TextActiveConverter}, ConverterParameter='1'}"
                            BorderBrush="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource BorderActiveConverter}, ConverterParameter='1'}"
                            Command="{x:Bind ViewModel.SelectTimeFilterCommand}" CommandParameter="Tuần"/>

                        <Button Content="Tháng" Padding="20,8" CornerRadius="12" BorderThickness="1"
                            Foreground="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource TextActiveConverter}, ConverterParameter='2'}"
                            BorderBrush="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource BorderActiveConverter}, ConverterParameter='2'}"
                            Command="{x:Bind ViewModel.SelectTimeFilterCommand}" CommandParameter="Tháng"/>

                        <Button Content="Năm" Padding="20,8" CornerRadius="12" BorderThickness="1"
                            Foreground="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource TextActiveConverter}, ConverterParameter='3'}"
                            BorderBrush="{x:Bind ViewModel.SelectedTimeFilter, Mode=OneWay, Converter={StaticResource BorderActiveConverter}, ConverterParameter='3'}"
                            Command="{x:Bind ViewModel.SelectTimeFilterCommand}" CommandParameter="Năm"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                        <CalendarDatePicker PlaceholderText="01/01/2024"/>
                        <TextBlock Text="-" VerticalAlignment="Center"/>
                        <CalendarDatePicker PlaceholderText="31/01/2024" Margin="0,0,20,0"/>
                        <Button>
                            <FontIcon Glyph="&#xE71C;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Summary Cards -->
            <Grid ColumnSpacing="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- TỔNG DOANH THU -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="TỔNG DOANH THU" Foreground="Gray" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalRevenue, Mode=OneWay}" FontSize="22" FontWeight="Bold" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Bind ViewModel.RevenueChange, Mode=OneWay}" Foreground="#28A745" FontSize="11"/>
                                <TextBlock Text=" so với tháng trước" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- LỢI NHUẬN ƯỚC TÍNH -->
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="LỢI NHUẬN ƯỚC TÍNH" Foreground="Gray" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                            <TextBlock Text="{x:Bind ViewModel.EstimatedProfit, Mode=OneWay}" FontSize="22" FontWeight="Bold" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Bind ViewModel.ProfitChange, Mode=OneWay}" Foreground="#28A745" FontSize="11"/>
                                <TextBlock Text=" so với tháng trước" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TRUNG BÌNH ĐƠN -->
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="TRUNG BÌNH ĐƠN" Foreground="Gray" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                            <TextBlock Text="{x:Bind ViewModel.AverageOrder, Mode=OneWay}" FontSize="22" FontWeight="Bold" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Bind ViewModel.AverageOrderChange, Mode=OneWay}" Foreground="#E8533F" FontSize="11"/>
                                <TextBlock Text=" mỗi lượt khách" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="#FFF3E0" CornerRadius="12" Padding="10"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40">
                            <FontIcon Glyph="&#xE7BF;" Foreground="#D97724" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- TỔNG ĐƠN HÀNG -->
                <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="TỔNG ĐƠN HÀNG" Foreground="Gray" FontSize="11" FontWeight="SemiBold" CharacterSpacing="50"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalOrders, Mode=OneWay}" FontSize="22" FontWeight="Bold" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Bind ViewModel.OrdersChange, Mode=OneWay}" Foreground="#28A745" FontSize="11"/>
                                <TextBlock Text=" đơn hoàn thành" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="#E8F5E9" CornerRadius="12" Padding="10"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40">
                            <FontIcon Glyph="&#xE9D2;" Foreground="#28A745" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Charts Row -->
            <Grid ColumnSpacing="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bar Chart: Doanh thu tuần này -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Biểu đồ Doanh thu tuần này" FontWeight="Bold" FontSize="18"/>
                                <TextBlock Text="Thống kê chi tiết doanh thu và lợi nhuận theo ngày" Foreground="Gray" FontSize="13"/>
                            </StackPanel>
                            <HyperlinkButton Content="Tải báo cáo ↗" HorizontalAlignment="Right" Foreground="#D97724"/>
                        </Grid>

                        <!-- Y-Axis Labels + Bar Chart Area -->
                        <Grid Margin="0,20,0,0" Height="280">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Y-axis labels -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                <TextBlock Text="8200000" Foreground="Gray" FontSize="10" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                <TextBlock Text="6150000" Foreground="Gray" FontSize="10" HorizontalAlignment="Right" Margin="0,45,8,0"/>
                                <TextBlock Text="4100000" Foreground="Gray" FontSize="10" HorizontalAlignment="Right" Margin="0,45,8,0"/>
                                <TextBlock Text="2050000" Foreground="Gray" FontSize="10" HorizontalAlignment="Right" Margin="0,45,8,0"/>
                                <TextBlock Text="0" Foreground="Gray" FontSize="10" HorizontalAlignment="Right" Margin="0,45,8,0"/>
                            </StackPanel>

                            <!-- Bar chart -->
                            <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ViewModel.WeeklyChartData, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RevenueChartItem">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="50">
                                            <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                                <!-- Revenue bar -->
                                                <Border Background="#D97724" CornerRadius="4,4,0,0" Width="18"
                                                        Height="{x:Bind RevenueBarHeight, Mode=OneWay}"/>
                                                <!-- Profit bar -->
                                                <Border Background="#F0A04B" CornerRadius="4,4,0,0" Width="18"
                                                        Height="{x:Bind ProfitBarHeight, Mode=OneWay}"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind DayLabel, Mode=OneWay}" FontSize="11" Foreground="Gray"
                                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="10" Height="10" Fill="#D97724"/>
                                <TextBlock Text="Doanh thu" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="10" Height="10" Fill="#F0A04B"/>
                                <TextBlock Text="Lợi nhuận" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Donut Chart: Cơ cấu Danh mục -->
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Cơ cấu Danh mục" FontWeight="Bold" FontSize="18"/>
                        <TextBlock Text="Tỷ trọng doanh thu theo nhóm sản phẩm" Foreground="Gray" FontSize="13"/>

                        <!-- Placeholder donut chart -->
                        <Grid Height="180" Margin="0,20,0,10">
                            <Ellipse Width="150" Height="150" StrokeThickness="30" Stroke="#F5D0A9"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="150" Height="150" StrokeThickness="30" Stroke="#E8533F"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     StrokeDashArray="2.4,7.6" StrokeDashOffset="0"/>
                            <Ellipse Width="150" Height="150" StrokeThickness="30" Stroke="#F0A04B"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     StrokeDashArray="1.8,8.2" StrokeDashOffset="2.4"/>
                            <Ellipse Width="150" Height="150" StrokeThickness="30" Stroke="#D97724"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     StrokeDashArray="3.4,6.6" StrokeDashOffset="4.2"/>
                        </Grid>

                        <!-- Category legend list -->
                        <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryBreakdown, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryItem">
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center"
                                            Fill="{Binding ColorHex}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name, Mode=OneWay}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center">
                                            <Run Text="{x:Bind Percentage.ToString(), Mode=OneWay}"/><Run Text="%"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Footer -->
            <TextBlock Text="© 2024 POS Cà Phê • v1.0.4 • Hệ thống quản lý vận hành thông minh"
                       HorizontalAlignment="Center" Margin="0,0,0,20" FontSize="11" Foreground="Gray"/>

        </StackPanel>
    </ScrollViewer>
</Page>
