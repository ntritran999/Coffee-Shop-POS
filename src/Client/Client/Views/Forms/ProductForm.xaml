<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Client.Views.Forms.ProductForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views.Forms"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="12" Spacing="8">
        <TextBlock x:Name="DialogTitle" FontSize="18" FontWeight="Bold"/>

        <TextBox x:Name="NameBox" Header="Tên sản phẩm" Text="{x:Bind Product.Name, Mode=TwoWay}"/>
        <TextBox x:Name="PriceBox" Header="Giá" InputScope="Number" Text="{x:Bind Product.Price, Mode=TwoWay}"/>
        <TextBox x:Name="UnitBox" Header="Đơn vị" InputScope="Number" Text="{x:Bind Product.Unit, Mode=TwoWay}"/>
        <TextBox x:Name="CategoryID" Header="Category" InputScope="Number" Text="{x:Bind Product.CategoryID, Mode=TwoWay}"/>

        <TextBlock Text="Ảnh (URL hoặc đường dẫn file)"/>
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ImageBox" Grid.Column="0" Text="{x:Bind Product.Image, Mode=TwoWay}"/>
            <Button Grid.Column="1" Content="Chọn ảnh..." Click="PickImageButton_Click"/>
        </Grid>

        <TextBlock x:Name="ValidationErrorText" Foreground="Red" TextWrapping="WrapWholeWords" Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
