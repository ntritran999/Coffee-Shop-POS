<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:vm="using:Client.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="30">
            <StackPanel Spacing="28">

                <!-- Page Header -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Cài đặt chung" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Quản lý các thông số vận hành và kết nối máy chủ cho hệ thống POS của bạn."
                               Foreground="Gray" FontSize="14"/>
                </StackPanel>

                <!-- Section: Hiển thị -->
                <Border Background="White" CornerRadius="12" Padding="28">
                    <StackPanel Spacing="24">
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Background="#FFF3E0" CornerRadius="10" Width="40" Height="40">
                                <FontIcon Glyph="&#xE7B5;" Foreground="#D97724" FontSize="18"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Hiển thị" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Tùy chỉnh cách các danh sách và giao diện được hiển thị cho người dùng."
                                           Foreground="Gray" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Items Per Page -->
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xF0E2;" FontSize="14" Foreground="#D97724"/>
                                    <TextBlock Text="Số lượng mục mỗi trang" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="Chọn số lượng sản phẩm/đơn hàng hiển thị trong các bảng danh sách."
                                           Foreground="Gray" FontSize="13" Margin="22,4,0,0"/>
                            </StackPanel>

                            <StackPanel Name="ItemsPerPageBtnPanel" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="5" Padding="16,8" CornerRadius="8" MinWidth="44"
                                        Command="{x:Bind ViewModel.SetItemsPerPageCommand}" CommandParameter="5"
                                        Background="Transparent"
                                        Click="ItemsPerPage_Click"/>
                                <Button Content="10" Padding="16,8" CornerRadius="8" MinWidth="44"
                                        Command="{x:Bind ViewModel.SetItemsPerPageCommand}" CommandParameter="10"
                                        Background="Transparent"
                                        Click="ItemsPerPage_Click"/>
                                <Button Content="15" Padding="16,8" CornerRadius="8" MinWidth="44"
                                        Command="{x:Bind ViewModel.SetItemsPerPageCommand}" CommandParameter="15"
                                        Background="Transparent"
                                        Click="ItemsPerPage_Click"/>
                                <Button Content="20" Padding="16,8" CornerRadius="8" MinWidth="44"
                                        Command="{x:Bind ViewModel.SetItemsPerPageCommand}" CommandParameter="20"
                                        Background="Transparent"
                                        Click="ItemsPerPage_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Separator -->
                        <Border Height="1" Background="#F0F0F0"/>

                        <!-- Remember Last Screen -->
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE81C;" FontSize="14" Foreground="#D97724"/>
                                    <TextBlock Text="Ghi nhớ màn hình cuối" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="Tự động quay lại màn hình đang làm việc dở khi khởi động lại ứng dụng."
                                           Foreground="Gray" FontSize="13" Margin="22,4,0,0"/>
                            </StackPanel>

                            <ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center"
                                          IsOn="{x:Bind ViewModel.RememberLastScreen, Mode=TwoWay}"
                                          OnContent="" OffContent=""/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section: Kết nối -->
                <Border Background="White" CornerRadius="12" Padding="28">
                    <StackPanel Spacing="24">
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Background="#FFF3E0" CornerRadius="10" Width="40" Height="40">
                                <FontIcon Glyph="&#xE774;" Foreground="#D97724" FontSize="18"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Kết nối" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Cấu hình thông số kỹ thuật để kết nối với cơ sở dữ liệu và máy chủ trung tâm."
                                           Foreground="Gray" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Host + Port -->
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Địa chỉ máy chủ (Host)" FontWeight="SemiBold"/>
                                <TextBox PlaceholderText="192.168.1.100"
                                         Text="{x:Bind ViewModel.ServerHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Description>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE701;" FontSize="12" Foreground="Gray"/>
                                        </StackPanel>
                                    </TextBox.Description>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Cổng kết nối (Port)" FontWeight="SemiBold"/>
                                <TextBox PlaceholderText="8080"
                                         Text="{x:Bind ViewModel.ServerPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Test Connection -->
                        <Button Padding="20,10" CornerRadius="8"
                                BorderBrush="#D97724" Foreground="#D97724" Background="Transparent"
                                Command="{x:Bind ViewModel.TestConnectionCommand}">
                            <TextBlock Text="Kiểm tra kết nối"/>
                        </Button>

                        <!-- Connection Status -->
                        <TextBlock Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                                   Foreground="#28A745" FontSize="13"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Bar: Last Updated + Buttons -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="30,16">
            <Grid>
                <TextBlock Text="{x:Bind ViewModel.LastUpdated, Mode=OneWay}"
                           Foreground="Gray" FontSize="13" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                    <Button Content="Hủy bỏ" Padding="24,10" CornerRadius="8"
                            Command="{x:Bind ViewModel.CancelSettingsCommand}"/>
                    <Button Padding="24,10" CornerRadius="8"
                            Background="#D97724" Foreground="White"
                            Command="{x:Bind ViewModel.SaveSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                            <TextBlock Text="Lưu thay đổi"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
