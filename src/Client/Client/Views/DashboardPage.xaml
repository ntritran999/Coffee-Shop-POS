<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:converter="using:Client.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d">

    <Page.Resources>
        <converter:SelectedRangeToBrushConverter x:Key="RangeToBrushConverter"/>
    </Page.Resources>

    <ScrollViewer Padding="20">
        <Grid ColumnSpacing="20" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
          

            <Grid Grid.Row="0" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Tổng sản phẩm" Foreground="Gray" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="142" FontSize="28" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Text="▲ +5 so với hôm qua" Foreground="Green" Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Đơn hàng hôm nay" Foreground="Gray" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="86" FontSize="28" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Text="▲ +12% so với hôm qua" Foreground="Green" Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Doanh thu hôm nay" Foreground="Gray" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="142" FontSize="28" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Text="▲ +15.4% so với hôm qua" Foreground="Green" Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            
            <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                CornerRadius="12" Padding="24" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Doanh thu theo thời gian" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Thống kê doanh thu 30 ngày gần nhất" Foreground="Gray" FontSize="12"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Spacing="8" 
                            VerticalAlignment="Top">

                            <Button Content="Tuần này" CornerRadius="8"
                                    Command="{x:Bind ViewModel.LoadWeekCommand}"
                                    Background="{x:Bind ViewModel.SelectedRange, Converter={StaticResource RangeToBrushConverter}, ConverterParameter=Week, Mode=OneWay}"/>

                            <Button Content="Tháng này" CornerRadius="8"
                                    Command="{x:Bind ViewModel.LoadMonthCommand}"
                                    Background="{x:Bind ViewModel.SelectedRange, Converter={StaticResource RangeToBrushConverter}, ConverterParameter=Month, Mode=OneWay}"/>

                            <Button Content="Quý này" CornerRadius="8"
                                    Command="{x:Bind ViewModel.LoadQuarterCommand}"
                                    Background="{x:Bind ViewModel.SelectedRange, Converter={StaticResource RangeToBrushConverter}, ConverterParameter=Quarter, Mode=OneWay}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Chart Placeholder: Bạn nên dùng thư viện WinUI Chart như WinUI.Charting hoặc LiveCharts2 -->
                    <Grid Grid.Row="1" Height="300" Margin="0,20,0,0">
                        <lvc:CartesianChart Series="{x:Bind ViewModel.SeriesCollection, Mode=OneWay}">
                            
                        </lvc:CartesianChart>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="15" BorderThickness="1" BorderBrush="#EEE">
                    <StackPanel>
                        <TextBlock Text="Top 5 bán chạy" FontWeight="Bold" Margin="0,0,0,10"/>

                        <ListView ItemsSource="{x:Bind ViewModel.TopSellingProducts, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:TopSellingProductItem">
                                    <Grid ColumnSpacing="12" Padding="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon/Ảnh sản phẩm -->
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Source="{x:Bind product.Image}" Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Tên và giá sản phẩm -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind product.Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind product.Price, Mode=OneWay}" Foreground="Gray" FontSize="12"/>
                                        </StackPanel>

                                        <!-- Tổng số lượt bán -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind totalSold}" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="Lượt bán" FontSize="10" Foreground="Gray" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" Margin="20,0" BorderThickness="1" BorderBrush="#EEE">
                    <StackPanel>
                        <TextBlock Text="Sắp hết hàng" FontWeight="Bold" Margin="0,0,0,10"/>

                        <ListView SelectionMode="None" Padding="0">
                            <ListViewItem HorizontalContentAlignment="Stretch" Padding="0,8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="16" Foreground="Gray" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Sữa đặc Ngôi Sao" FontWeight="Medium" FontSize="14"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Tồn: " FontSize="12" Foreground="Gray"/>
                                            <TextBlock Text="5 Hộp" FontSize="12" Foreground="Orange" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="Nhập hàng" 
                                        Padding="8,2" FontSize="11"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{ThemeResource SystemAccentColor}"/>
                                </Grid>
                            </ListViewItem>

                            <MenuFlyoutSeparator/>
                            
                                <ListViewItem HorizontalContentAlignment="Stretch" Padding="0,8">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="16" Foreground="Gray"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Hạt Cà Phê Robusta" FontWeight="Medium" FontSize="14"/>
                                            <TextBlock Text="Tồn: 2 Kg" FontSize="12" Foreground="Orange"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Nhập hàng" Padding="8,2" FontSize="11" Background="Transparent" Foreground="{ThemeResource SystemAccentColor}"/>
                                    </Grid>
                                </ListViewItem>

                            <MenuFlyoutSeparator/>

                            <ListViewItem HorizontalContentAlignment="Center" Margin="0,10,0,0">
                                <Button Background="Transparent" BorderThickness="1" BorderBrush="#DDD" CornerRadius="20" Padding="20,5">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Street" />
                                        <TextBlock Text="Xem danh sách kho" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </ListViewItem>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="15" BorderThickness="1" BorderBrush="#EEE">

                    <StackPanel>
                        <TextBlock Text="Đơn hàng gần đây" FontWeight="Bold"/>

                        <ListView SelectionMode="None" Padding="0" ItemsSource="{x:Bind ViewModel.RecentOrders, Mode=OneWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:RecentOrderItem">
                                    <Border Background="#FFF9F2" CornerRadius="12" Padding="15" BorderThickness="1" BorderBrush="#F0F0F0" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Header: OrderID + Table + Status -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Border Background="#F0F0F0" CornerRadius="4" Padding="6,2">
                                                        <TextBlock Text="{x:Bind BillID}" 
                                                   FontSize="10" FontWeight="Bold" Foreground="Gray"/>
                                                    </Border>
                                                    <TextBlock Text="{x:Bind TableID}" 
                                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1" 
                                                           Text="{x:Bind StatusText}"
                                                           Foreground="Orange"
                                                           FontSize="11" VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Total Amount -->
                                            <TextBlock Grid.Row="1" 
                                       Text="{x:Bind TotalAmount}" 
                                       FontSize="18" FontWeight="Bold" Margin="0,8,0,0"/>

                                            <!-- Time Ago -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="5" Margin="0,4,0,0">
                                                <SymbolIcon Symbol="Clock" Foreground="Gray" Width="12"/>
                                                <TextBlock Text="{x:Bind DateCheckIn}" 
                                           Foreground="Gray" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button
                            Background="#D2691E" Foreground="White" 
                            HorizontalAlignment="Stretch" Height="50" 
                            CornerRadius="8" Margin="0,15,0,0">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <SymbolIcon Symbol="Shop" Margin="0,0,10,0"/>
                                    <TextBlock Text="Mở POS Bán Hàng"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </ScrollViewer>
</Page>
