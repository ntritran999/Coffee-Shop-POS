<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.TablePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="20" Margin="36" Padding="16" Background="#fbfaf8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xF0E2;" />
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="So do ban" FontWeight="Bold" FontSize="24"/>
                        <TextBlock Text="Tong quan" FontWeight="Light" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <Button CornerRadius="12" Content="Tat ca"/>
                    <Button CornerRadius="12" Content="Lau 1"/>
                    <Button CornerRadius="12" Content="Lau 2"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="5">
                <Button>
                    <StackPanel Orientation="Horizontal" Spacing="5" Padding="10">
                        <FontIcon Glyph="&#xE710;" />
                        <TextBlock Text="Them ban" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Lan cap nhat cuoi: " FontStyle="Italic" FontWeight="Light"/>
            </StackPanel>
        </Grid>
        <Border Grid.Row="1" CornerRadius="12" Background="White" BorderBrush="Black" BorderThickness="1" Padding="12">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15" Margin="30, 0, 0, 0">
                    <TextBlock Text="Ban trong( )"/>
                    <TextBlock Text="Dang dung( )"/>
                    <TextBlock Text="Dang don( )"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1">
                    <TextBlock Text="|"/>
                    <TextBlock>
                        <Run Text="Tong so: "/>
                        <Run Text="12 ban"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
        <ListView Grid.Row="2" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="200" Height="300" Background="White" CornerRadius="12">
                        <Grid Padding="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Vertical" >
                                <TextBlock Text="KHU VUC A" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="Ban 01" FontWeight="Bold" FontSize="24" Margin="0, 0, 0, 20"/>
                                <Border CornerRadius="12" BorderBrush="Black" BorderThickness="1" Padding="12,4" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon Glyph="&#xE716;" />
                                        <TextBlock Text="Co nguoi"/>
                                    </StackPanel>
                                </Border>
                                <Grid Margin="0, 10, 0, 20" RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Suc chua:"/>
                                    <TextBlock Grid.Column="0" Grid.Row="1" Text="Da ngoi:"/>
                                    <TextBlock Grid.Column="1" Grid.Row="0" Text="2 khach" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Grid.Row="1" Text="45 phut"/>
                                </Grid>
                            </StackPanel>
                            <Button Grid.Row="1" HorizontalAlignment="Stretch">
                                <TextBlock Text="Xem don" FontSize="20"/>
                            </Button>
                        </Grid>
                        
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <toolkit:WrapPanel VerticalSpacing="30"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <x:String>Test1</x:String>
            <x:String>Test1</x:String>
            <x:String>Test1</x:String>
            <x:String>Test1</x:String>
            <x:String>Test1</x:String>
            <x:String>Test1</x:String>
            <x:String>Test1</x:String>
        </ListView>
    </Grid>
</Page>
