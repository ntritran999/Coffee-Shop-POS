<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Client.Views.TablePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.Views"
    xmlns:converter="using:Client.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converter:FormatTableStatus x:Key="FormatTableStatus"/>
        <converter:TableStatusIconConverter x:Key="StatusIcon"/>
        <converter:BillStatusConverter x:Key="BillStatus"/>
    </Page.Resources>
    <Grid>
        <SplitView x:Name="ViewBillsSplitView" OpenPaneLength="532" CompactPaneLength="48" DisplayMode="Overlay"
               PanePlacement="Right">
            <SplitView.Pane>
                <Grid RowSpacing="32" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Danh sách đơn hàng" Style="{StaticResource TitleLargeTextBlockStyle}"/>
                    <Border Grid.Row="1" CornerRadius="8" BorderThickness="0,1,0,1" Background="White" Padding="16">
                        <ListView SelectionMode="None"
                                  ItemsSource="{x:Bind ViewModel.Bills, Mode=OneWay}">
                            <ListView.Header>
                                <Border BorderThickness="0,0,0,1" Padding="20, 12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="4*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2.5*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="Mã đơn" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Thời gian" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Tổng tiền (đ)" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Trạng thái"
                                            FontWeight="SemiBold" FontSize="13"
                                            HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Black" BorderThickness="0, 0, 0, 1" Padding="0, 0, 0, 16" Margin="0, 0, 0, 16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="4*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2.5*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding BillID}"
                                                FontWeight="SemiBold"
                                                FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DateCheckIn}"
                                                FontSize="13"
                                                VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding TotalAmount}"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3" Text="{Binding Status, Converter={StaticResource BillStatus}}" FontSize="12" FontWeight="SemiBold" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </SplitView.Pane>
            <Grid RowSpacing="20" Margin="36" Padding="16" Background="#fbfaf8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xF0E2;" />
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Sơ đồ bàn" FontWeight="Bold" FontSize="24"/>
                                <TextBlock Text="Tổng quan trạng thái chỗ ngồi" FontWeight="Light" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button CornerRadius="12" Content="Tât cả"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="5">
                        <Button Click="AddTable_Click" IsEnabled="{x:Bind Negate(ViewModel.LoadCommand.IsRunning), Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8" Padding="10">
                                <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                <TextBlock Text="Thêm bàn" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="1" CornerRadius="12" Background="White" BorderBrush="Black" BorderThickness="1" Padding="12">
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" Margin="30, 0, 0, 0">
                            <TextBlock Text="Bàn trống(">
                    <Run Text="{x:Bind ViewModel.NumEmpty, Mode=OneWay}"/><Run Text=")"/>
                            </TextBlock>
                            <TextBlock Text="Đang phục vụ(">
                    <Run Text="{x:Bind ViewModel.NumServing, Mode=OneWay}"/><Run Text=")"/>
                            </TextBlock>
                            <TextBlock Text="Đang dọn(">
                    <Run Text="{x:Bind ViewModel.NumCleaning, Mode=OneWay}"/><Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="1">
                            <TextBlock Text="|"/>
                            <TextBlock>
                    <Run Text="Tổng số: "/>
                    <Run Text="{x:Bind ViewModel.Tables.Count, Mode=OneWay}"/>
                    <Run Text="bàn"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
                <ProgressRing Grid.Row="2" IsActive="{x:Bind ViewModel.LoadCommand.IsRunning, Mode=OneWay}"/>
                <ListView Grid.Row="2" SelectionMode="None"
              ItemsSource="{x:Bind ViewModel.Tables, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="200" Height="300" Background="White" CornerRadius="12">
                                <Grid Padding="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Vertical" >
                                        <Grid  Margin="0, 0, 0, 16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TableName}" FontWeight="Bold" FontSize="24"/>
                                            <Button Click="EditTable_Click" Grid.Column="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE713;" />
                                            </Button>
                                        </Grid>
                                        <Border CornerRadius="12" BorderBrush="Black" BorderThickness="1" Padding="12,4" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="{Binding Status, Converter={StaticResource StatusIcon}}" />
                                                <TextBlock Text="{Binding Status, Converter={StaticResource FormatTableStatus}}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <Button Click="ViewBills_Click" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
                                        <TextBlock Text="Xem đơn" FontSize="20"/>
                                    </Button>
                                </Grid>

                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <toolkit:WrapPanel VerticalSpacing="30"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
            </Grid>
        </SplitView>
        <Grid Background="#33000000" 
              Visibility="{x:Bind ViewModel.AreBillsLoading, Mode=OneWay}"
              HorizontalAlignment="Stretch" 
              VerticalAlignment="Stretch">
            <ProgressRing IsActive="True" />
        </Grid>
    </Grid>
</Page>
